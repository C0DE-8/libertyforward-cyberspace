{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!assets/|favicon.ico|favicon.svg|favicon-16.png|favicon-32.png|apple-touch-icon.png|logo.png|icons.svg).*)",
      "destination": "/index.html"
    }
  ]
}
